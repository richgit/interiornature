---
import Layout from '../layouts/Layout.astro';
import homeData from '../../content/home/home.json';
---

<Layout title="Interior Nature | Living Aquatic Ecosystems">
    <section class="hero-section">
        <h1>{homeData.headline}</h1>
    </section>

    {homeData.headerImage && (
        <div class="featured-image-container">
            <img src={homeData.headerImage} alt="Interior Nature" class="featured-image" />
        </div>
    )}

    <section class="content-section">
        <div class="text-block">
            <Fragment set:html={homeData.body} />
        </div>
    </section>

    <section class="closing-section">
        <a href="/contact" class="btn">Get in Touch</a>
    </section>
</Layout>