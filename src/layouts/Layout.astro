---
import { getCollection } from 'astro:content';

const { title = "Interior Nature | Living Aquatic Ecosystems" } = Astro.props;
const currentPath = Astro.url.pathname;

// Fetch all CMS pages and sort them by menuOrder
const allPages = await getCollection('pages');
const menuPages = allPages
  .filter(page => page.data.showInMenu)
  .sort((a, b) => (a.data.menuOrder || 10) - (b.data.menuOrder || 10));
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <!-- Import a crisp, modern geometric font -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style is:global>
        :root {
            --bg-color: #0f0f11;
            --card-bg: rgba(255, 255, 255, 0.03);
            --card-border: rgba(255, 255, 255, 0.08);
            --text-main: #f5f5f7;
            --text-muted: #9e9ea7;
            --accent: #d4c391; /* Slightly brighter, cleaner gold */
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            line-height: 1.7;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* Frosted Glass Sticky Header */
        header {
            padding: 1.2rem 5%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--card-border);
            background: rgba(15, 15, 17, 0.8);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .logo-container {
            display: flex;
            align-items: center;
            text-decoration: none;
        }

        /* Scaled down logo for a sleeker, modern nav bar */
        .logo-img {
            height: 75px;
            width: auto;
            object-fit: contain;
            transition: transform 0.3s ease;
        }

        .logo-img:hover {
            transform: scale(1.02);
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 2.5rem;
        }

        nav a {
            color: var(--text-muted);
            text-decoration: none;
            transition: all 0.2s ease;
            font-size: 0.9rem;
            font-weight: 500;
            letter-spacing: 0.5px;
        }

        nav a:hover, nav a.active {
            color: var(--text-main);
            text-shadow: 0 0 12px rgba(255, 255, 255, 0.3);
        }

        main {
            flex: 1;
            padding: 5rem 5%;
            max-width: 960px;
            margin: 0 auto;
            width: 100%;
        }

        .hero-section {
            text-align: center;
            margin-bottom: 5rem;
        }

        h1 {
            font-size: 3.2rem;
            font-weight: 300;
            margin-bottom: 1.5rem;
            letter-spacing: -0.5px;
            line-height: 1.15;
            background: linear-gradient(180deg, #ffffff 0%, #b3b3b3 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .content-section {
            display: flex;
            flex-direction: column;
            gap: 4rem;
            margin-bottom: 4rem;
        }

        .text-block {
            max-width: 760px;
            margin: 0 auto;
            width: 100%;
        }

        h2 {
            font-size: 1.75rem;
            font-weight: 400;
            margin-bottom: 1rem;
            letter-spacing: -0.3px;
            color: var(--accent);
        }

        h3 {
            font-size: 1.2rem;
            font-weight: 600;
            margin-top: 2rem;
            margin-bottom: 0.8rem;
            color: var(--text-main);
        }

        p, .text-block p {
            color: var(--text-muted);
            font-size: 1.05rem;
            line-height: 1.8;
            margin-bottom: 1.2rem;
            font-weight: 300;
        }

        /* Modernized Contact Card with subtle glow */
        .contact-card {
            background: var(--card-bg);
            padding: 3rem 2rem;
            border: 1px solid var(--card-border);
            border-radius: 16px;
            width: 100%;
            max-width: 540px;
            margin: 2rem auto;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
            backdrop-filter: blur(8px);
        }

        .contact-item {
            margin-bottom: 1.5rem;
        }

        .contact-item:last-child {
            margin-bottom: 0;
        }

        .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 2.5px;
            color: var(--text-muted);
            display: block;
            margin-bottom: 0.4rem;
            font-weight: 600;
        }

        .value {
            font-size: 1.2rem;
            color: var(--text-main);
            text-decoration: none;
            font-weight: 400;
            transition: color 0.2s ease;
        }

        a.value:hover {
            color: var(--accent);
        }

        /* Featured Image with rounded corners and border */
/* Featured Image - Sleek Widescreen Banner */
/* Featured Image - Contain Mode (No Cropping) */
.featured-image-container {
    width: 100%;
    max-width: 900px;
    margin: 0 auto 3rem auto;
    padding: 1.5rem; /* Adds breathing room around logos/illustrations */
    display: flex;
    justify-content: center;
    align-items: center;
    border: 1px solid var(--card-border);
    border-radius: 16px;
    background-color: var(--card-bg);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    min-height: 280px; /* Gives it a nice structured height */
}

.featured-image {
    max-width: 100%;
    max-height: 350px;
    width: auto;
    height: auto;
    object-fit: contain; /* Ensures the whole image fits without cropping top or bottom */
    display: block;
}
/* Mobile Screen Adjustment */
@media (max-width: 768px) {
    .featured-image-container {
        aspect-ratio: 16 / 9; /* Slightly taller on mobile screens for better framing */
        margin-bottom: 2rem;
    }
}
        .closing-section {
            text-align: center;
            border-top: 1px solid var(--card-border);
            padding-top: 5rem;
            max-width: 600px;
            margin: 0 auto 5rem auto;
        }

        /* Sleek Button with smooth hover fill */
        .btn {
            display: inline-block;
            padding: 0.9rem 2.4rem;
            background: rgba(255, 255, 255, 0.05);
            color: var(--text-main);
            border: 1px solid var(--card-border);
            border-radius: 50px;
            text-decoration: none;
            font-size: 0.95rem;
            font-weight: 500;
            letter-spacing: 0.5px;
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .btn:hover {
            background: var(--text-main);
            color: var(--bg-color);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(255, 255, 255, 0.1);
        }

        footer {
            text-align: center;
            padding: 3rem 2rem;
            font-size: 0.85rem;
            color: var(--text-muted);
            border-top: 1px solid var(--card-border);
            font-weight: 300;
        }

        @media (max-width: 768px) {
            header { padding: 1rem 5%; }
            .logo-img { height: 55px; }
            h1 { font-size: 2.3rem; }
            main { padding: 3rem 5%; }
            .content-section { gap: 2.5rem; }
            .btn { width: 100%; text-align: center; }
        }

/* Styling for Rich Text Content Blocks */
.text-block h2 {
    font-size: 1.8rem;
    color: var(--accent);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 400;
}

.text-block h3 {
    font-size: 1.3rem;
    color: var(--text-main);
    margin-top: 2rem;
    margin-bottom: 0.8rem;
}

.text-block p {
    margin-bottom: 1.5rem;
    line-height: 1.8;
    color: var(--text-muted);
}

.text-block ul, .text-block ol {
    margin: 0 0 1.5rem 1.5rem;
    color: var(--text-muted);
}

.text-block li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
}

.text-block strong {
    color: var(--text-main);
    font-weight: 600;
}
    </style>
</head>
<body>

    <header>
        <a href="/" class="logo-container">
            <img src="/images/logo.png" alt="Interior Nature" class="logo-img">
        </a>
        <nav>
            <ul>
                <li><a href="/" class={currentPath === "/" ? "active" : ""}>Home</a></li>
                {menuPages.map(page => (
                    <li>
                        <a
                          href={`/${page.slug}`}
                          class={currentPath.includes(page.slug) ? "active" : ""}
                        >
                          {page.data.title}
                        </a>
                    </li>
                ))}
            </ul>
        </nav>
    </header>

    <main>
        <slot />
    </main>

    <footer>
        &copy; 2026 Interior Nature. All rights reserved.
    </footer>

</body>
</html>